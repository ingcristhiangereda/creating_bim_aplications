{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/node_modules/@thatopen/fragments/dist/Worker/worker.mjs",
        "destination": "/worker.mjs"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
